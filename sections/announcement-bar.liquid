{%- if section.settings.show_announcement -%}
  <div class="announcement-bar" role="region" aria-label="Announcement" style="background: var(--gradient-announcement); color: var(--color-white);">
    <div class="announcement-bar__marquee">
      {%- for i in (1..4) -%}
        <div class="announcement-bar__marquee-item">
          <span class="marquee-separator"></span>
          <span>{{ section.settings.text }}</span>
          <span class="marquee-separator"></span>
          <span>{{ section.settings.text_2 | default: section.settings.text }}</span>
        </div>
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show Announcement",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Announcement Text",
      "default": "Free Delivery in Ireland on orders over €80"
    },
    {
      "type": "text",
      "id": "text_2",
      "label": "Second Announcement Text (Optional)",
      "default": "100% Original Imported Fragrances"
    }
  ]
}
{% endschema %}
