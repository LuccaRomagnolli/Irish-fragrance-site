<footer class="site-footer">
  <div class="footer-container page-width">
    <div class="footer-grid">
      <!-- Column 1: Brand Logo & Story -->
      <div class="footer-col brand-col">
        <div class="footer-logo">
          {%- if section.settings.logo != blank -%}
            <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" class="footer-logo-img">
          {%- else -%}
            <img src="{{ 'logo.png' | asset_url }}" alt="THE KING OF PARFUMS" class="footer-logo-img" width="180">
          {%- endif -%}
        </div>
        <p class="footer-brand-text text-small">
          Since 2016, The King of Parfums transforms passions into fragrances, bringing what is most sophisticated and authentic in the perfumery universe.
        </p>
      </div>

      <!-- Column 2: INFORMATION & HELP & SUPPORT -->
      <div class="footer-col links-col">
        <div class="footer-sub-section">
          <h4 class="footer-subheading">INFORMATION</h4>
          <ul class="footer-menu list-unstyled">
            <li><a href="/pages/about-us" class="footer-link text-small">About Us</a></li>
            <li><a href="/pages/youtube" class="footer-link text-small">YouTube Channel</a></li>
          </ul>
        </div>
        
        <div class="footer-sub-section" style="margin-top: 1.5rem;">
          <h4 class="footer-subheading">HELP & SUPPORT</h4>
          <ul class="footer-menu list-unstyled">
            <li><a href="/pages/shipping-delivery" class="footer-link text-small">Shipping & Delivery Policy</a></li>
            <li><a href="/pages/returns-refunds" class="footer-link text-small">Returns & Refunds Policy</a></li>
            <li><a href="/pages/track-order" class="footer-link text-small">Track Your Order</a></li>
            <li><a href="/pages/contact" class="footer-link text-small">Contact</a></li>
          </ul>
        </div>
      </div>

      <!-- Column 3: CUSTOMER SERVICE & FOLLOW US -->
      <div class="footer-col contact-col">
        <div class="footer-sub-section">
          <h4 class="footer-subheading">CUSTOMER SERVICE</h4>
          <ul class="footer-contact-list list-unstyled">
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="icon icon-phone" style="width: 18px; height: 18px; margin-right: 6px; vertical-align: middle;"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>11958579189</span>
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="icon icon-whatsapp" style="width: 18px; height: 18px; margin-right: 6px; vertical-align: middle;"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z" fill="currentColor"/></svg>
              <span>11 95857-9189</span>
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="icon icon-email" style="width: 18px; height: 18px; margin-right: 6px; vertical-align: middle;"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke-linecap="round" stroke-linejoin="round"/><polyline points="22,6 12,13 2,6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span>contato@thekingofparfums.com.br</span>
            </li>
          </ul>
        </div>

        <div class="footer-sub-section" style="margin-top: 1.5rem;">
          <h4 class="footer-subheading">FOLLOW US</h4>
          <div class="footer-social-icons">
            <a href="https://youtube.com" target="_blank" rel="noopener" class="footer-social-link">
              <svg viewBox="0 0 24 24" fill="currentColor" style="width: 20px; height: 20px;"><path d="M23.498 6.163a3.003 3.003 0 0 0-2.11-2.11C19.518 3.545 12 3.545 12 3.545s-7.518 0-9.388.508a3.003 3.003 0 0 0-2.11 2.11C0 8.033 0 12 0 12s0 3.967.502 5.837a3.003 3.003 0 0 0 2.11 2.11c1.87.508 9.388.508 9.388.508s7.518 0 9.388-.508a3.003 3.003 0 0 0 2.11-2.11C24 15.967 24 12 24 12s0-3.967-.502-5.837zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            </a>
            <a href="https://tiktok.com" target="_blank" rel="noopener" class="footer-social-link">
              <svg viewBox="0 0 24 24" fill="currentColor" style="width: 18px; height: 18px;"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.17-2.86-.74-3.94-1.74-.22-.2-.43-.43-.62-.67-.02 3.28.01 6.56-.01 9.84-.07 2.04-.74 4.07-2.12 5.56-1.57 1.75-4.04 2.76-6.42 2.65-2.61-.05-5.21-1.39-6.61-3.6-1.48-2.26-1.66-5.32-.47-7.75 1.12-2.37 3.56-3.97 6.19-4.22.01 1.4.01 2.8 0 4.2-1.07.08-2.17.47-2.85 1.34-.73.91-.84 2.21-.36 3.27.46 1.08 1.6 1.83 2.76 1.88 1.13.06 2.3-.5 2.87-1.5.34-.57.43-1.25.41-1.9-.01-4.71 0-9.42-.01-14.13z"/></svg>
            </a>
            <a href="https://instagram.com" target="_blank" rel="noopener" class="footer-social-link">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 18px; height: 18px;"><rect x="2" y="2" width="20" height="20" rx="5" ry="5" stroke-linecap="round" stroke-linejoin="round"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" stroke-linecap="round" stroke-linejoin="round"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="https://facebook.com" target="_blank" rel="noopener" class="footer-social-link">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 18px; height: 18px;"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Column 4: NEWSLETTER -->
      <div class="footer-col newsletter-col">
        <h4 class="footer-subheading">NEWSLETTER</h4>
        <p class="text-small newsletter-desc">
          Subscribe to receive emails from The King Of Parfums and get the latest news, including exclusive online pre-launches and new collections.
        </p>
        
        {%- form 'customer', id: 'FooterNewsletter', class: 'footer-newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="newsletter-fields-group">
            <input
              type="text"
              name="contact[first_name]"
              class="newsletter-custom-input"
              placeholder="Name"
              required
            >
            <div class="newsletter-email-field-wrapper">
              <input
                id="NewsletterForm--{{ section.id }}"
                type="email"
                name="contact[email]"
                class="newsletter-custom-input email-input"
                placeholder="Email"
                required
              >
              <button type="submit" class="newsletter-custom-submit-btn" name="commit" aria-label="Subscribe">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width: 16px; height: 16px;"><polyline points="9 18 15 12 9 6"/></svg>
              </button>
            </div>
          </div>
          {%- if form.posted_successfully? -%}
            <p class="newsletter-success text-small" style="margin-top: 0.5rem; color: var(--color-accent);">Thank you for subscribing!</p>
          {%- endif -%}
        {%- endform -%}
      </div>
    </div>

    <!-- Middle Badges Row: Shipping, Payment, Loja Segura -->
    <div class="footer-middle-badges">
      <div class="badge-group">
        <span class="badge-group-title">SHIPPING METHODS</span>
        <div class="badge-group-icons">
          <span class="badge-item-placeholder">Melhor Envio</span>
          <span class="badge-item-placeholder">Nuvem Envio</span>
          <span class="badge-item-placeholder">Correios</span>
        </div>
      </div>
      
      <div class="badge-group">
        <span class="badge-group-title">PAYMENT METHODS</span>
        <div class="badge-group-icons">
          <span class="badge-item-placeholder">Visa</span>
          <span class="badge-item-placeholder">Mastercard</span>
          <span class="badge-item-placeholder">Amex</span>
          <span class="badge-item-placeholder">Apple Pay</span>
          <span class="badge-item-placeholder">Google Pay</span>
          <span class="badge-item-placeholder">PayPal</span>
        </div>
      </div>

      <div class="badge-group">
        <span class="badge-group-title">SECURE SHOP</span>
        <div class="badge-group-icons">
          <span class="badge-item-placeholder">Google Safe Browsing</span>
          <span class="badge-item-placeholder">Secure SSL</span>
        </div>
      </div>
    </div>

    <!-- Bottom Row: Copyright & Creator -->
    <div class="footer-bottom-credits">
      <p class="text-small copyright-text">
        Copyright THE KING OF PARFUMS - 2026. All rights reserved.
      </p>
      <div class="weethub-logo">
        <span class="text-small" style="opacity: 0.7; margin-right: 0.25rem;">developed by</span>
        <span class="weethub-brand font-heading-style">weethub</span>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer Logo"
    }
  ]
}
{% endschema %}
