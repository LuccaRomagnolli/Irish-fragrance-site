{% comment %}
  Renders a product card for collection lists and featured collection grids.
  Accepts:
  - card_product: {Object} Product Liquid object
{% endcomment %}

<div class="product-card js-item-product" data-product-id="{{ card_product.id }}">
  <div class="product-card__image-wrapper">
    <a href="{{ card_product.url }}" class="product-card__image-link">
      {%- if card_product.featured_image != blank -%}
        {{ card_product.featured_image | image_url: width: 600 | image_tag: class: 'product-card__image', loading: 'lazy', sizes: '(min-width: 990px) 25vw, (min-width: 750px) 33vw, 50vw', widths: '165, 360, 533, 720, 940, 1066' }}
        
        {%- if card_product.images[1] != blank -%}
          {{ card_product.images[1] | image_url: width: 600 | image_tag: class: 'product-card__image hover-image', loading: 'lazy', sizes: '(min-width: 990px) 25vw, (min-width: 750px) 33vw, 50vw', widths: '165, 360, 533, 720, 940, 1066' }}
        {%- endif -%}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg product-card__image' }}
      {%- endif -%}
    </a>

    {%- unless card_product.available -%}
      <span class="badge badge--sold-out">Sold Out</span>
    {%- endunless -%}

    {%- if card_product.available -%}
      <button type="button" 
              class="product-card__quick-add-circle js-quick-add-btn" 
              data-variant-id="{{ card_product.selected_or_first_available_variant.id }}"
              aria-label="Add {{ card_product.title | escape }} to cart">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" stroke-linecap="round" stroke-linejoin="round"/><line x1="3" y1="6" x2="21" y2="6" stroke-linecap="round" stroke-linejoin="round"/><path d="M16 10a4 4 0 01-8 0" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    {%- endif -%}
  </div>
  
  <div class="product-card__info" style="text-align: center;">
    <span class="product-card__vendor" style="font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-text-muted); display: block; margin-bottom: 5px;">{{ card_product.vendor | default: shop.name }}</span>
    
    <h3 class="product-card__title" style="font-size: 1rem; font-weight: 600; margin-bottom: 8px;">
      <a href="{{ card_product.url }}">{{ card_product.title | escape }}</a>
    </h3>
    
    <div class="product-card__price-row" style="justify-content: center;">
      {%- if card_product.compare_at_price > card_product.price -%}
        <span class="product-card__price-compare" style="text-decoration: line-through; color: var(--color-text-muted); margin-right: 8px;">{{ card_product.compare_at_price | money }}</span>
      {%- endif -%}
      <span class="product-card__price">{{ card_product.price | money }}</span>
    </div>

    <div class="product-card__installments" style="font-size: 0.8rem; color: var(--color-text-muted); margin-top: 4px;">
      <span class="installments-text">or 6x of {{ card_product.price | divided_by: 6 | money }}</span>
    </div>
  </div>
</div>
