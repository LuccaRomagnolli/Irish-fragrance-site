<div class="service-banners-section" id="ServiceBanners-{{ section.id }}">
  <div class="page-width">
    <div class="service-banners-grid">
      {%- for block in section.blocks -%}
        <div class="service-banner-item" {{ block.shopify_attributes }}>
          <div class="service-banner-icon">
            {%- case block.settings.icon -%}
              {%- when 'quality' -%}
                <svg viewBox="0 0 24 24" class="icon service-icon" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke-linecap="round" stroke-linejoin="round"/><path d="M9 11l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {%- when 'fixation' -%}
                <svg viewBox="0 0 70 70" class="icon service-icon" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M35 16.25c-2.59 0-5.13.33-7.58.97V13.6c0-.23.19-.42.42-.42h14.33c.23 0 .42.19.42.42v3.63c-2.43-.65-4.97-.98-7.59-.98zM25.29 17.85c-4.22 1.45-8.09 3.86-11.35 7.1C8.29 30.58 5.19 38.08 5.19 46.06c0 8.9 3.94 17.27 10.79 22.96.76.63 1.73.98 2.71.98h32.62c.98 0 1.95-.35 2.71-.98 6.74-5.59 10.66-13.8 10.78-22.54.05-4.02-.7-7.94-2.24-11.66-1.49-3.58-3.64-6.81-6.38-9.61-3.29-3.35-7.2-5.81-11.47-7.3v-4.29c0-1.4-1.13-2.54-2.54-2.54H27.83c-1.4 0-2.54 1.13-2.54 2.54v4.25z" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {%- when 'original' -%}
                <svg viewBox="0 0 64 54" class="icon service-icon" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M47.56 0c.29 0 .56.12.75.34l15.31 17.5c.34.39.33.97-.02 1.34L32.98 52c-.19.2-.45.31-.73.31s-.54-.11-.73-.31L.89 19.18C.54 18.8.53 18.23.87 17.84L16.18.34c.19-.22.46-.34.75-.34h30.63z" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {%- when 'payment' -%}
                <svg viewBox="0 0 24 24" class="icon service-icon" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="4" width="22" height="16" rx="2" ry="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M1 10h22" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {%- when 'shipping' -%}
                <svg viewBox="0 0 24 24" class="icon service-icon" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 9H9V4H4v15h15v-5" stroke-linecap="round" stroke-linejoin="round"/><path d="M19 14h-5v5" stroke-linecap="round" stroke-linejoin="round"/><rect x="14" y="9" width="9" height="5" rx="1" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {%- endcase -%}
          </div>
          <div class="service-banner-text">
            <h3 class="service-banner-title font-body-style">{{ block.settings.title | escape }}</h3>
            <p class="service-banner-description text-muted">{{ block.settings.description | escape }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Service Features",
  "max_blocks": 5,
  "blocks": [
    {
      "type": "banner",
      "name": "Feature Badge",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon Type",
          "options": [
            { "value": "quality", "label": "Premium Quality" },
            { "value": "fixation", "label": "High Fixation" },
            { "value": "original", "label": "Original Products" },
            { "value": "payment", "label": "Easy Payment" },
            { "value": "shipping", "label": "Secure Shipping" }
          ],
          "default": "quality"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Premium Quality"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "The best fragrance brands for you"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Service Features List",
      "blocks": [
        { "type": "banner", "settings": { "icon": "quality", "title": "PREMIUM QUALITY", "description": "The best fragrance brands for you" } },
        { "type": "banner", "settings": { "icon": "fixation", "title": "HIGH LONGEVITY", "description": "Concentrated, long-lasting notes" } },
        { "type": "banner", "settings": { "icon": "original", "title": "100% ORIGINAL", "description": "Sourced directly from authorized importers" } },
        { "type": "banner", "settings": { "icon": "payment", "title": "EASY CHECKOUT", "description": "Flexible payment terms at checkout" } },
        { "type": "banner", "settings": { "icon": "shipping", "title": "SECURE SHIPPING", "description": "Delivered safely across Ireland" } }
      ]
    }
  ]
}
{% endschema %}
