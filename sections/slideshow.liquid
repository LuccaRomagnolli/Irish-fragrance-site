<div class="slideshow-section" id="Slideshow-{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="slideshow-wrapper">
    {%- for block in section.blocks -%}
      <div class="slide-item {% if forloop.first %}active{% endif %} slide-{{ block.id }}" {{ block.shopify_attributes }}>
        <!-- Desktop image -->
        {%- if block.settings.image_desktop != blank -%}
          <img src="{{ block.settings.image_desktop | image_url: width: 2000 }}" 
               alt="{{ block.settings.heading | default: 'Slide Image' | escape }}" 
               class="slide-img desktop-only" 
               loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
               sizes="100vw">
        {%- else -%}
          <div class="slide-img placeholder desktop-only">
            {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}

        <!-- Mobile image -->
        {%- if block.settings.image_mobile != blank -%}
          <img src="{{ block.settings.image_mobile | image_url: width: 1000 }}" 
               alt="{{ block.settings.heading | default: 'Slide Image' | escape }}" 
               class="slide-img mobile-only" 
               loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
               sizes="100vw">
        {%- elsif block.settings.image_desktop != blank -%}
          <img src="{{ block.settings.image_desktop | image_url: width: 1000 }}" 
               alt="{{ block.settings.heading | default: 'Slide Image' | escape }}" 
               class="slide-img mobile-only" 
               loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
               sizes="100vw">
        {%- else -%}
          <div class="slide-img placeholder mobile-only">
            {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}

        <div class="slide-overlay"></div>

        <div class="slide-content page-width">
          <div class="slide-box text-{{ block.settings.align }}">
            {%- if block.settings.heading != blank -%}
              <h2 class="slide-title h1 font-heading-style animate-on-scroll">{{ block.settings.heading | escape }}</h2>
            {%- endif -%}
            {%- if block.settings.subheading != blank -%}
              <p class="slide-subheading animate-on-scroll" style="transition-delay: 0.2s;">{{ block.settings.subheading | escape }}</p>
            {%- endif -%}
            {%- if block.settings.button_label != blank and block.settings.button_link != blank -%}
              <div class="slide-buttons">
                <a href="{{ block.settings.button_link }}" class="button button--primary">
                  {{ block.settings.button_label | escape }}
                </a>
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <!-- Slide navigation controls -->
    <div class="slideshow-controls page-width">
      <button class="slideshow-arrow prev" aria-label="Previous Slide">
        <svg viewBox="0 0 10 16" style="width: 10px; height: 16px; transform: scaleX(-1);"><path d="M1 1l7 7-7 7" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      
      <div class="slideshow-dots">
        {%- for block in section.blocks -%}
          <button class="slideshow-dot {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="Go to slide {{ forloop.index }}"></button>
        {%- endfor -%}
      </div>
      
      <button class="slideshow-arrow next" aria-label="Next Slide">
        <svg viewBox="0 0 10 16" style="width: 10px; height: 16px;"><path d="M1 1l7 7-7 7" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  {%- endif -%}
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const slideshow = document.querySelector('#Slideshow-{{ section.id }}');
    if (!slideshow) return;

    const slides = slideshow.querySelectorAll('.slide-item');
    const dots = slideshow.querySelectorAll('.slideshow-dot');
    const prevBtn = slideshow.querySelector('.slideshow-arrow.prev');
    const nextBtn = slideshow.querySelector('.slideshow-arrow.next');
    let currentIndex = 0;

    if (slides.length <= 1) return;

    function goToSlide(index) {
      slides[currentIndex].classList.remove('active');
      dots[currentIndex]?.classList.remove('active');
      
      currentIndex = (index + slides.length) % slides.length;
      
      slides[currentIndex].classList.add('active');
      dots[currentIndex]?.classList.add('active');
    }

    prevBtn?.addEventListener('click', () => goToSlide(currentIndex - 1));
    nextBtn?.addEventListener('click', () => goToSlide(currentIndex + 1));
    
    dots.forEach(dot => {
      dot.addEventListener('click', () => {
        const index = parseInt(dot.getAttribute('data-index'), 10);
        goToSlide(index);
      });
    });

    // Auto rotate every 6 seconds
    setInterval(() => {
      goToSlide(currentIndex + 1);
    }, 6000);
  });
</script>

{% schema %}
{
  "name": "Slideshow",
  "max_blocks": 6,
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image_desktop",
          "label": "Desktop Image"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Mobile Image (Optional)"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Luxury Perfumes"
        },
        {
          "type": "textarea",
          "id": "subheading",
          "label": "Subheading",
          "default": "Discover our collection of rare and precious notes."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        },
        {
          "type": "select",
          "id": "align",
          "label": "Text Alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "center"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Slideshow",
      "blocks": [
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
