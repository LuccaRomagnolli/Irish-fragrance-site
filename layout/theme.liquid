<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_accent }}">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'meta-tags' %}

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,400;0,6..96,700;1,6..96,400&family=Jost:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- CSS Variables from Shopify Customizer -->
    <style>
      :root {
        --font-heading: {{ settings.font_heading | default: 'Bodoni Moda, serif' }};
        --font-body: {{ settings.font_body | default: 'Jost, sans-serif' }};

        --color-bg: {{ settings.color_bg | default: '#fcf8f4' }};
        --color-bg-secondary: {{ settings.color_bg_secondary | default: '#ffffff' }};
        --color-text: {{ settings.color_text | default: '#000000' }};
        --color-text-muted: {{ settings.color_text_muted | default: '#555555' }};
        --color-accent: {{ settings.color_accent | default: '#c3934f' }};
        --color-gold: {{ settings.color_gold | default: '#c3934f' }};
        --color-white: {{ settings.color_white | default: '#FFFFFF' }};
        --color-border: {{ settings.color_border | default: '#e5dec9' }};
        
        --transition-smooth: all 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        --transition-fast: all 0.15s ease-in-out;
      }
    </style>

    {{ 'theme.css' | asset_url | stylesheet_tag }}
    
    <!-- Header scripts -->
    {{ content_for_header }}

    <script>
      document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
      window.theme = {
        strings: {
          addToCart: {{ 'products.product.add_to_cart' | t | json }},
          soldOut: {{ 'products.product.sold_out' | t | json }},
          unavailable: {{ 'products.product.unavailable' | t | json }},
          addingToCart: {{ 'general.cart.adding' | t | json }},
          addedToCart: {{ 'general.cart.added' | t | json }}
        },
        routes: {
          cartAddUrl: '{{ routes.cart_add_url }}',
          cartChangeUrl: '{{ routes.cart_change_url }}',
          cartUpdateUrl: '{{ routes.cart_update_url }}'
        },
        moneyFormat: {{ shop.money_format | json }}
      };
    </script>
    <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>
  </head>

  <body class="template-{{ template.name }} gradient">
    <a class="skip-to-content-link button visually-hidden" href="#MainContent">
      Skip to content
    </a>

    {% section 'announcement-bar' %}
    {% section 'header' %}

    <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% section 'footer' %}

    {% render 'cart-drawer' %}

    <ul hidden>
      <li id="a11y-refresh-page-message">Choosing a selection results in a full page refresh.</li>
      <li id="a11y-new-window-message">Opens in a new window.</li>
    </ul>
  </body>
</html>
