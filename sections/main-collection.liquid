{%- paginate collection.products by section.settings.products_per_page -%}
  <div class="main-collection section-padding page-width" data-section="{{ section.id }}">
    <div class="collection-header-row">
      <div class="collection-header__left-group">
        <h1 class="collection-title font-heading-style h1">{{ collection.title }}</h1>
        {%- if collection.description != blank -%}
          <div class="collection-description text-muted">
            {{ collection.description | strip_html }}
          </div>
        {%- endif -%}
        <p class="product-count text-small">
          {{ collection.products_count }} {{ collection.products_count | pluralize: 'resultado encontrado', 'resultados encontrados' }}
        </p>
      </div>

      <div class="collection-header__right-group">
        <button type="button" class="collection-filter-toggle-btn">
          <svg class="icon icon-filter" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" style="width: 16px; height: 16px; margin-right: 6px; vertical-align: middle;"><path d="M2 4h16M4 10h12M7 16h6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Exibir Filtro
        </button>
        
        <div class="collection-sort-by-wrapper">
          <span class="sort-by-label text-small text-muted">Ordenar por</span>
          <div class="select-wrapper">
            <select name="sort_by" class="collection-sort-select">
              <option value="manual">Mais vendidos</option>
              <option value="price-ascending">Preço: menor para maior</option>
              <option value="price-descending">Preço: maior para menor</option>
            </select>
          </div>
        </div>
      </div>
    </div>

    <div class="grid grid--4-col" role="list">
      {%- for product in collection.products -%}
        <div class="grid__item">
          {% render 'product-card', card_product: product %}
        </div>
      {%- else -%}
        <p class="collection-empty text-center">No fragrances found in this collection.</p>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <nav class="pagination text-center" role="navigation" aria-label="Pagination">
        <ul class="pagination__list list-unstyled" role="list">
          {%- if paginate.previous -%}
            <li>
              <a href="{{ paginate.previous.url }}" class="pagination__item">
                &laquo; Previous
              </a>
            </li>
          {%- endif -%}

          {%- for part in paginate.parts -%}
            <li>
              {%- if part.is_link -%}
                <a href="{{ part.url }}" class="pagination__item">{{ part.title }}</a>
              {%- else -%}
                {%- if part.title == paginate.current_page -%}
                  <span class="pagination__item pagination__item--current" aria-current="page">{{ part.title }}</span>
                {%- else -%}
                  <span class="pagination__item">{{ part.title }}</span>
                {%- endif -%}
              {%- endif -%}
            </li>
          {%- endfor -%}

          {%- if paginate.next -%}
            <li>
              <a href="{{ paginate.next.url }}" class="pagination__item">
                Next &raquo;
              </a>
            </li>
          {%- endif -%}
        </ul>
      </nav>
    {%- endif -%}
  </div>
{%- endpaginate -%}

{% schema %}
{
  "name": "Collection Grid",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 24,
      "step": 4,
      "label": "Products per page",
      "default": 12
    }
  ]
}
{% endschema %}
